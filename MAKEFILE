CC = cc68x

all: game.tos tst_psg.tos

game.tos: main.o model.o events.o input.o render.o raster.o mem.o music.o psg.o sfx.o set_vid.o
	gen set_vid.o $(CC) main.o model.o events.o input.o render.o raster.o music.o psg.o mem.o sfx.o -o game.tos

tst_psg.tos: tst_psg.o psg.o music.o sfx.o
	$(CC) tst_psg.o psg.o music.o sfx.o -o tst_psg.tos

main.o: main.c model.h events.h render.h input.h bitmap.h
	$(CC) -c main.c

bitmap.o: bitmap.c bitmap.h
	$(CC) -c bitmap.c

model.o: model.c model.h types.h bitmap.h mem.h sfx.h
	$(CC) -c model.c

events.o: events.c events.h
	$(CC) -c events.c

input.o: input.c input.h types.h
	$(CC) -c input.c

raster.o: raster.c raster.h
	$(CC) -c raster.c

render.o: render.c render.h types.h raster.h model.h bitmap.h
	$(CC) -c render.c

mem.o: mem.c mem.h types.h
	$(CC) -c mem.c

music.o: music.c music.h types.h
	$(CC) -c music.c

psg.o: psg.c psg.h types.h
	$(CC) -c psg.c

tst_psg.o: tst_psg.c psg.h types.h
	$(CC) -c tst_psg.c

sfx.o: sfx.c sfx.h psg.h
	$(CC) -c sfx.c

set_vid.o: set_vid.s
    gen -L2 set_vid.s -o set_vid.o