CC = cc68x
gen = gen

all: game.tos

game.tos: main.o model.o events.o input.o render.o raster.o mem.o music.o psg.o sfx.o isr.o set_vid.o ikbd_isr.o
	$(CC) main.o model.o events.o input.o render.o raster.o mem.o music.o psg.o sfx.o isr.o set_vid.o ikbd_isr.o -o game.tos

%.o: %.s
	$(gen) -L2 $<

main.o: main.c model.h events.h render.h input.h bitmap.h set_vid.s
	$(CC) -c main.c

bitmap.o: bitmap.c bitmap.h
	$(CC) -c bitmap.c

model.o: model.c model.h types.h bitmap.h mem.h sfx.h
	$(CC) -c model.c

events.o: events.c events.h
	$(CC) -c events.c

input.o: input.c input.h types.h
	$(CC) -c input.c

raster.o: raster.c raster.h
	$(CC) -c raster.c

render.o: render.c render.h types.h raster.h model.h bitmap.h
	$(CC) -c render.c

mem.o: mem.c mem.h types.h
	$(CC) -c mem.c

music.o: music.c music.h types.h
	$(CC) -c music.c

psg.o: psg.c psg.h types.h
	$(CC) -c psg.c

tst_psg.o: tst_psg.c psg.h types.h
	$(CC) -c tst_psg.c

sfx.o: sfx.c sfx.h psg.h
	$(CC) -c sfx.c

isr.o: isr.c ISR.h
	$(CC) -c isr.c